# NextAuth (required)
# Generate: openssl rand -base64 32
AUTH_SECRET=
# Base URL app – BẮT BUỘC trùng với Redirect URI trong Google Console. Không dấu / cuối.
# Local:  http://localhost:3003   (đúng port đang chạy; mở bằng localhost không dùng 127.0.0.1)
# Netlify: https://kendrive.netlify.app
AUTH_URL=http://localhost:3003
NEXTAUTH_URL=http://localhost:3003

# Google OAuth – https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins:  http://localhost:3000  và  https://kendrive.netlify.app
# Authorized redirect URIs – thêm CẢ HAI (nếu vừa dev local vừa deploy):
#   http://localhost:3000/api/auth/callback/google
#   https://kendrive.netlify.app/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
