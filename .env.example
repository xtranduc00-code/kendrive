# NextAuth (required)
# Generate: openssl rand -base64 32
AUTH_SECRET=
# Đúng URL app đang chạy (port phải trùng với Redirect URI trong Google Console)
AUTH_URL=http://localhost:3000

# Google OAuth – create at https://console.cloud.google.com/apis/credentials
# Enable Drive API and create OAuth 2.0 Client ID (Web app).
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
